<Window x:Class="todolist.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MVVM TODO List" Height="400" Width="350">

    <StackPanel Margin="15">
        <TextBlock Text="Název úkolu:" />
        <TextBox Text="{Binding NewTaskText, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10" Height="25" />

        <TextBlock Text="Deadline (pouze datum):" />
        <DatePicker SelectedDate="{Binding NewTaskDeadline}" Margin="0,5,0,10" Height="25" />

        <Button Content="Přidat úkol" Command="{Binding AddTaskCommand}" Height="30" Background="Green" />

        <TextBlock Text="Seznam úkolů:" Margin="0,15,0,5" FontWeight="Bold" />

        <ListBox ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}" Height="130">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding Deadline, StringFormat=\{0:dd. MM. yyyy\}}" Foreground="Red" Margin="0,0,10,0" />
                        <TextBlock Text="{Binding Text}" />
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Content="Odebrat vybraný" Command="{Binding RemoveTaskCommand}" Margin="0,15,0,0" Height="30" Background="Red" />
    </StackPanel>
</Window>